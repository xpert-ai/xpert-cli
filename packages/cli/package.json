{
  "name": "@xpert-ai/xpert-cli",
  "version": "0.0.1",
  "description": "Local-first terminal coding agent for the xpert platform.",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "xpert": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --clean",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@xpert-ai/xpert-sdk": "0.0.3",
    "commander": "^13.1.0",
    "diff": "^7.0.0",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@xpert-cli/contracts": "workspace:*"
  }
}
